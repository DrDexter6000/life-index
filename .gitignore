# ============================================
# Life Index - Git Ignore
# ============================================

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/
ENV/

# ----- IDE -----
.vscode/
.idea/
*.swp
*.swo
*~

# ----- OS -----
.DS_Store
Thumbs.db

# ----- 临时文件 -----
.cowork-temp/
tmp/
temp/
*.tmp
*.log
nul

# ----- 测试输出 -----
.pytest_cache/
.pytest_tmp/
.coverage
coverage*.xml
htmlcov/
cov_report/
.ruff_cache/
.benchmarks/
.recovery/

# ----- E2E测试报告 -----
tests/reports/

# ----- 运行时数据（用户本地生成）-----
# 注意：这些数据在 ~/Documents/Life-Index/，不在项目目录
# 但以防万一，也加上
Journals/
by-topic/
attachments/
*.db
*.sqlite
*.sqlite3
vector_store/
fts_index/

# ----- 开发阶段文档 -----
docs/.dev-archive/
/.archive/

# ----- 内部战略与开发文档（不公开）-----
.strategy/

# ----- 敏感文件 -----
.env
.env.local
.env.*
secrets.yaml
secrets.json
credentials.json
*.pem
*.key
.sisyphus/
.sisyphus-runtime-check.json
.sisyphus-verify-shot.json
.sisyphus_inline_png_glows.py
docs/archive/

# ----- OpenCode 工具文件 -----
.opencode/
.claude/

# ----- Windows 下载标记 -----
*.Zone.Identifier

# ----- Tailwind CSS 构建工具 -----
# tailwindcss.exe 是独立CLI工具（~40MB），不应提交到Git
# 部署时从GitHub下载或使用npm安装
tailwindcss.exe
node_modules/
package-lock.json

# ----- 本地启动脚本 -----
start-claude-here.bat
Kimi_here.bat

# ----- 会话交接文件 -----
.handoff.md

# ----- 本地备份 / 原型临时文件 -----
*.backup
