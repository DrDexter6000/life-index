{
  "name": "upgrade",
  "description": "Diagnose Life Index program freshness and report whether clean replacement is required.",
  "parameters": {
    "type": "object",
    "properties": {
      "plan": {
        "type": "boolean",
        "description": "Build a read-only upgrade plan."
      },
      "apply": {
        "type": "boolean",
        "description": "Return a read-only no-op or a reinstall-required error without mutating the environment."
      },
      "json": {
        "type": "boolean",
        "description": "Emit JSON output."
      }
    },
    "oneOf": [
      {
        "required": ["plan"]
      },
      {
        "required": ["apply"]
      }
    ]
  },
  "output": {
    "type": "object",
    "required": ["success", "schema_version", "command", "mode", "data"],
    "properties": {
      "success": {
        "type": "boolean"
      },
      "schema_version": {
        "type": "string",
        "const": "m36.upgrade.v0"
      },
      "command": {
        "type": "string",
        "const": "upgrade"
      },
      "mode": {
        "type": "string",
        "enum": ["plan", "apply"]
      },
      "data": {
        "type": "object"
      },
      "error": {
        "type": "object"
      }
    }
  }
}
