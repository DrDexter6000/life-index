{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "name": "entity",
  "description": "管理实体图谱",
  "version": "1.1.1",
  "parameters": {
    "type": "object",
    "properties": {
      "action": {"type": "string"},
      "data": {"type": "object"},
      "query": {"type": "string"},
      "id": {"type": "string"}
    },
    "required": []
  },
  "returns": {
    "type": "object",
    "properties": {}
  },
  "examples": [],
  "entity_graph_alias_schema": {
    "description": "v1.1.1 alias metadata extension — backward compatible with string-only aliases",
    "aliases": {
      "oneOf": [
        {
          "type": "array",
          "items": {"type": "string"},
          "description": "Legacy shape: list of alias strings"
        },
        {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "source": {"type": "string", "default": "system"},
              "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0, "default": 1.0},
              "created_at": {"type": "string", "format": "date-time"}
            },
            "required": ["name"]
          },
          "description": "v1.1.1 shape: list of alias objects with metadata"
        }
      ]
    },
    "alias_metadata": {
      "type": "object",
      "description": "Optional explicit metadata map from alias name to metadata object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "source": {"type": "string", "default": "system"},
          "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0, "default": 1.0},
          "created_at": {"type": "string", "format": "date-time"}
        }
      }
    },
    "backcompat": {
      "old_yaml_load_defaults": {
        "source": "system",
        "confidence": 1.0,
        "created_at": "load-time ISO-8601"
      }
    }
  },
  "entity_graph_relationship_schema": {
    "description": "v1.2 relationship edge metadata extension — backward compatible with bare {target, relation} edges",
    "relationship": {
      "type": "object",
      "properties": {
        "target": {"type": "string"},
        "relation": {"type": "string"},
        "weight": {"type": "number"},
        "supporting_journal_ids": {
          "type": "array",
          "items": {"type": "string"}
        },
        "evidence": {
          "type": "array",
          "items": {"type": "string"},
          "default": []
        },
        "source": {
          "type": "string",
          "enum": ["seed", "review", "user", "agent", "system"],
          "default": "system"
        },
        "created_at": {"type": "string", "format": "date-time"},
        "status": {
          "type": "string",
          "enum": ["confirmed", "candidate"],
          "default": "confirmed"
        },
        "start": {"type": "string"},
        "end": {"type": "string"}
      },
      "required": ["target", "relation"]
    },
    "backcompat": {
      "legacy_bare_edge_defaults": {
        "evidence": [],
        "source": "system",
        "created_at": "load-time ISO-8601",
        "status": "confirmed"
      }
    },
    "merge_tombstones": {
      "description": "Merged entities are preserved under target.merged_entities[] so entity --unmerge can restore the absorbed record.",
      "required_fields": [
        "id",
        "target_id",
        "source",
        "merged_at",
        "entity",
        "transferred_aliases",
        "transferred_relationships",
        "rewired_relationships"
      ]
    },
    "distinct_review_records": {
      "description": "User-confirmed non-duplicate decisions are preserved per entity under not_duplicate_of[]; keep_separate writes symmetric records and undo_keep_separate removes them.",
      "not_duplicate_of": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "target": {"type": "string"},
            "source": {
              "type": "string",
              "enum": ["seed", "review", "user", "agent", "system"],
              "default": "user"
            },
            "created_at": {"type": "string", "format": "date-time"}
          },
          "required": ["target", "source", "created_at"]
        }
      }
    }
  }
}
